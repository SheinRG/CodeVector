# Copy this file to ".env" and fill in your real Supabase connection string.
#
# Where to find it:
#   Supabase dashboard -> your project -> "Connect" (top bar)
#   -> "Connection string" -> "Transaction pooler" (port 6543, recommended for
#   serverless / Render) OR "Session pooler" / "Direct connection".
#
# IMPORTANT: replace [YOUR-PASSWORD] with your database password and keep the
# "?sslmode=require" at the end (Supabase requires SSL).
DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Port the server listens on. Render sets this automatically; locally it
# defaults to 3000 if unset.
PORT=3000

# How many products the seed script creates. Defaults to 200000.
SEED_COUNT=200000
